{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Q20396/codex-long-horizon-skill/schemas/package-manifest.schema.json",
  "title": "LHE Package Layer Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "skill_id", "default_profile", "profiles", "components", "separate_skills", "migration"],
  "properties": {
    "$schema": {"type": "string"},
    "schema_version": {"const": "1.0"},
    "skill_id": {"const": "long-horizon-engineering"},
    "default_profile": {"type": "string", "minLength": 1},
    "profiles": {"type": "object", "minProperties": 1, "additionalProperties": {"$ref": "#/$defs/profile"}},
    "components": {"type": "object", "required": ["core", "bundled-optional"], "additionalProperties": {"$ref": "#/$defs/component"}},
    "separate_skills": {"type": "array", "items": {"$ref": "#/$defs/separateSkill"}},
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["physical_layout_changed", "default_install_changed", "legacy_checker_fallback"],
      "properties": {"physical_layout_changed": {"type": "boolean"}, "default_install_changed": {"type": "boolean"}, "legacy_checker_fallback": {"type": "boolean"}}
    }
  },
  "$defs": {
    "profile": {"type": "object", "additionalProperties": false, "required": ["components", "separate_skills"], "properties": {"components": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}, "separate_skills": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}}},
    "component": {"type": "object", "additionalProperties": false, "required": ["layer", "required", "paths"], "properties": {"layer": {"enum": ["core", "bundled-optional"]}, "required": {"type": "boolean"}, "paths": {"$ref": "#/$defs/paths"}}},
    "separateSkill": {"type": "object", "additionalProperties": false, "required": ["skill_id", "layer", "required_in_source_package", "paths"], "properties": {"skill_id": {"type": "string", "minLength": 1}, "layer": {"const": "separate-skill"}, "required_in_source_package": {"type": "boolean"}, "paths": {"$ref": "#/$defs/paths"}}},
    "paths": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^\\.agents/skills/[a-z0-9-]+/[^/].*$"}}
  }
}
