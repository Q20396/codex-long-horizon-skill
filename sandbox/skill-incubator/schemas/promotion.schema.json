{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Incubator Promotion Recommendation",
  "type": "object",
  "required": ["experiment_id", "status", "recommended_status", "approved_status", "automatic_transition", "customer_decision", "authorization_source", "license_compatible", "implementation_exists", "execution_authorized", "scores", "gate_results", "regressions", "unverified_claims", "rollback_status"],
  "properties": {
    "experiment_id": {"type": "string"},
    "source_commits": {"type": "array", "items": {"pattern": "^[0-9a-f]{40}$"}},
    "status": {"const": "locked"},
    "recommended_status": {"const": "locked"},
    "approved_status": {"const": "locked"},
    "automatic_transition": {"const": false},
    "customer_decision": {"enum": ["not_approved", "approved", "rejected"]},
    "authorization_source": {"const": "none"},
    "license_compatible": {"const": false},
    "human_approval_required": {"const": true},
    "implementation_exists": {"const": false},
    "execution_authorized": {"const": false},
    "scores": {"type": "object"},
    "gate_results": {"type": "array", "maxItems": 0},
    "regressions": {"type": "array", "maxItems": 0},
    "unverified_claims": {"type": "array"},
    "recommended_layer": {"type": "string"},
    "rollback_status": {"const": "not_tested"}
  },
  "additionalProperties": false
}
