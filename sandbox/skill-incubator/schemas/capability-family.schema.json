{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "capability-family.schema.json",
  "title": "Locked Capability Family",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "family_id", "name", "objective", "responsibilities", "included_patterns",
    "excluded_patterns", "current_experiments", "candidate_experiments",
    "recommended_layer", "execution_boundary", "catalog_visible",
    "recommendation_eligible", "execution_routing_allowed"
  ],
  "properties": {
    "family_id": {"type": "string", "pattern": "^FAMILY-[0-9]{3}$"},
    "name": {"type": "string", "minLength": 1},
    "objective": {"type": "string", "minLength": 1},
    "responsibilities": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "included_patterns": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^PAT-[0-9]{3}$"}},
    "excluded_patterns": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "current_experiments": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^MAD-SKILL-0(?:0[1-9]|1[01])$"}},
    "candidate_experiments": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^MAD-SKILL-01[2-4]$"}},
    "recommended_layer": {"enum": ["core", "bundled-optional", "separate-skill", "sandbox", "sandbox-only-methodology", "rejected_pending_verification"]},
    "execution_boundary": {"enum": ["design_only", "separate_approval", "restricted_domain"]},
    "catalog_visible": {"type": "boolean"},
    "recommendation_eligible": {"const": false},
    "execution_routing_allowed": {"const": false}
  }
}
