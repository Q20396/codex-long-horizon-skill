{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "proposal-evidence.schema.json",
  "title": "Pinned Proposal Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["experiment_id", "proposal_path", "proposal_sha256", "proposal_commit", "sections"],
  "properties": {
    "experiment_id": {"type": "string", "pattern": "^MAD-SKILL-0(?:0[1-9]|1[01])$"},
    "proposal_path": {"type": "string", "pattern": "^sandbox/skill-incubator/experiments/MAD-SKILL-0(?:0[1-9]|1[01])/proposal\\.md$"},
    "proposal_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "proposal_commit": {"const": "418497b9918f8f0af1f3868af69f54a57773f586"},
    "sections": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["evidence_id", "heading", "line_start", "line_end", "normalized_excerpt_sha256", "supports"],
        "properties": {
          "evidence_id": {"type": "string", "minLength": 1},
          "heading": {"type": "string", "minLength": 1},
          "line_start": {"type": "integer", "minimum": 1},
          "line_end": {"type": "integer", "minimum": 1},
          "normalized_excerpt_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "supports": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["objective", "non_goal", "input", "output", "permission", "execution_boundary", "candidate_gap"]}}
        }
      }
    }
  }
}
