{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Base Experiment Design-Mapping Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "experiment_id",
    "name",
    "status",
    "source_proposal_path",
    "source_proposal_sha256",
    "mapping_basis",
    "coverage_validation",
    "objective",
    "non_goals",
    "inputs",
    "outputs",
    "permissions",
    "covered_patterns",
    "excluded_patterns",
    "known_gaps",
    "recommended_layer",
    "routing_eligible"
  ],
  "properties": {
    "experiment_id": {"type": "string", "pattern": "^MAD-SKILL-0(?:0[1-9]|1[01])$"},
    "name": {"type": "string", "minLength": 1},
    "status": {"type": "string", "const": "locked"},
    "source_proposal_path": {"type": "string", "pattern": "^sandbox/skill-incubator/experiments/MAD-SKILL-0(?:0[1-9]|1[01])/proposal\\.md$"},
    "source_proposal_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "mapping_basis": {"type": "string", "const": "design_mapping"},
    "coverage_validation": {"type": "string", "const": "not_runtime_verified"},
    "objective": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "non_goals": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "inputs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "outputs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["read", "write", "network", "external_services"],
      "properties": {
        "read": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "write": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "network": {"type": "boolean", "const": false},
        "external_services": {"type": "boolean", "const": false}
      }
    },
    "covered_patterns": {"type": "array", "items": {"type": "string", "pattern": "^PAT-[0-9]{3}$"}},
    "excluded_patterns": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "known_gaps": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "recommended_layer": {"type": "string", "minLength": 1},
    "routing_eligible": {"type": "boolean", "default": false, "const": false}
  }
}
